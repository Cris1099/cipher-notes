<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Cipher" parent="android:Theme.Material.NoTitleBar">
        <item name="android:windowBackground">@color/void_bg</item>
        <item name="android:statusBarColor">@color/void_bg</item>
        <item name="android:navigationBarColor">@color/void_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    <style name="Theme.Cipher.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/void_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Cipher</item>
    </style>
</resources>
